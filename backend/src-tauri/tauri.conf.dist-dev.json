{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "HiFiShifter",
    "version": "0.1.0-beta.9",
    "identifier": "com.arounder.hifishifter",
    "build": {
        "beforeDevCommand": "node ../../scripts/tauri-before-dev.mjs",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../../frontend/dist",
        "beforeBuildCommand": "npm --prefix ../../frontend run build"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "HiFiShifter",
                "width": 1400,
                "height": 900,
                "visible": true,
                "dragDropEnabled": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": {
            "resources/models/nsf_hifigan/pc_nsf_hifigan.onnx": "models/nsf_hifigan/pc_nsf_hifigan.onnx",
            "resources/models/nsf_hifigan/config.json": "models/nsf_hifigan/config.json",
            "resources/models/hnsep/hnsep.onnx": "models/hnsep/hnsep.onnx",
            "resources/models/hnsep/config.yaml": "models/hnsep/config.yaml"
        },
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
